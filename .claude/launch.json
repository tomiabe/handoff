{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ws-server",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd server && node server.js"],
      "port": 8080
    },
    {
      "name": "web-dev",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "NEXT_PUBLIC_WS_URL=ws://localhost:8080 npm run dev"],
      "port": 3000
    }
  ]
}
